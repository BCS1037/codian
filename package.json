{
  "name": "codianz",
  "version": "1.0.2",
  "description": "Codian - coding agents embedded in Obsidian sidebar",
  "main": "main.js",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.mjs",
    "build:css": "node scripts/build-css.mjs",
    "dev": "npm run build:css && node esbuild.config.mjs",
    "build": "node scripts/build.mjs production",
    "check:providers": "node scripts/check-provider-inventory.mjs",
    "check:performance": "node scripts/check-startup-performance.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"{src,tests}/**/*.ts\"",
    "lint:store": "eslint \"{src,tests}/**/*.ts\"",
    "lint:fix": "npm run lint -- --fix",
    "test": "node scripts/run-tests.js",
    "test:unit": "node scripts/run-jest.js",
    "test:integration": "node scripts/run-jest.js --selectProjects integration",
    "test:architecture": "node --test scripts/check-architecture-boundaries.test.mjs",
    "test:watch": "node scripts/run-jest.js --watch",
    "test:coverage": "node scripts/run-jest.js --coverage",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "security:secrets": "node scripts/check-secrets.mjs",
    "licenses:check": "node scripts/check-production-licenses.mjs",
    "check:diff": "git diff --check",
    "verify": "npm run typecheck && npm run lint && npm run check:providers && npm run test && npm run build && npm run check:performance && npm run licenses:check && npm run security:secrets && npm run check:diff",
    "version": "node scripts/sync-version.js && git add manifest.json"
  },
  "keywords": [
    "claude-code",
    "obsidian",
    "obsidian-plugin",
    "productivity",
    "ide"
  ],
  "author": "BCS",
  "license": "AGPL-3.0-only",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "eslint-plugin-simple-import-sort": "^14.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "obsidian": "latest",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.209",
    "@codemirror/commands": "6.8.1",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.38.6",
    "@modelcontextprotocol/sdk": "~1.29.0",
    "smol-toml": "^1.6.1",
    "tslib": "^2.8.1"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "hono": "4.12.26",
    "js-yaml": "4.2.0"
  }
}
